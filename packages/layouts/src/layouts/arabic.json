{
  "id": "arabic",
  "name": "Arabic (العربية)",
  "language": "ar",
  "script": "arabic",
  "rtl": true,
  "rows": [
    [
      { "code": "Backquote", "char": "ذ", "charShift": "ّ" },
      { "code": "Digit1", "char": "١", "charShift": "!" },
      { "code": "Digit2", "char": "٢", "charShift": "@" },
